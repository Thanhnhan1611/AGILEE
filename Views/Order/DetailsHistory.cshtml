@model WebBanHang.Models.TbOrder
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-geo-alt-fill"></i> THÔNG TIN NHẬN HÀNG</h5>
        </div>
        <div class="card-body bg-light">
            <div class="row">
                <div class="col-md-4">
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Người nhận</p>
                    <p class="fw-bold text-dark fs-5">@(Model.Customer?.Name ?? "N/A")</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Số điện thoại</p>
                    <p class="fw-bold text-dark fs-5">@(Model.Customer?.Phone ?? "N/A")</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Trạng thái đơn hàng</p>
                    
                    @* CẬP NHẬT LOGIC TRẠNG THÁI *@
                    @if (Model.Status == 0)
                    {
                        <span class="badge bg-secondary px-3 py-2">Đã hủy</span>
                    }
                    else if (Model.Status == 1)
                    {
                        <span class="badge bg-warning text-dark px-3 py-2">Đang chờ xử lý</span>
                    }
                    else if (Model.Status == 2)
                    {
                        <span class="badge bg-info text-dark px-3 py-2">Đang giao hàng</span>
                    }
                    else
                    {
                        <span class="badge bg-success px-3 py-2">Đã hoàn thành</span>
                    }
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <p class="mb-1 text-muted small text-uppercase fw-bold">Địa chỉ giao hàng</p>
                    <p class="text-dark border-start border-3 border-primary ps-3">@(Model.Customer?.Address ?? "Chưa có địa chỉ")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">DANH SÁCH SẢN PHẨM</h5>
                <a href="/Order/History" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại lịch sử</a>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end pe-4">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.TbOrderDetails)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center py-2">
                                        @* Lưu ý: Kiểm tra đường dẫn ảnh của bạn là ~/images/ hay trực tiếp từ URL *@
                                        <img src="@item.Product?.Image" class="rounded shadow-sm me-3" style="width: 80px; height: 80px; object-fit: cover;" onerror="this.src='/images/no-image.png'" />
                                        <div>
                                            <div class="fw-bold text-primary">@item.Product?.Name</div>
                                            <small class="text-muted">Mã SP: #@item.ProductId</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center fw-bold">@item.Price.ToString("#,##0") đ</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill px-3">@item.Quanlity</span>
                                </td>
                                <td class="text-end pe-4 fw-bold text-danger">
                                    @((item.Price * item.Quanlity).ToString("#,##0")) đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 py-4 text-end pe-4">
            <h4 class="fw-bold text-dark">TỔNG THANH TOÁN: 
                <span class="text-danger ms-2">@Model.TbOrderDetails.Sum(x => x.Price * x.Quanlity).ToString("#,##0") VNĐ</span>
            </h4>
        </div>
    </div>
</div>