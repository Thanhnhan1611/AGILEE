@model WebBanHang.Models.TbOrder
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container my-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-4">
            <h4 class="mb-0"><i class="bi bi-receipt"></i> Chi Tiết Đơn Hàng</h4>
            <span class="badge bg-warning text-dark fs-6">
                @(Model.Status == 1 ? "Đang xử lý" : (Model.Status == 2 ? "Đang giao" : "Hoàn thành"))
            </span>
        </div>
        
        <div class="card-body p-4">
            <div class="row mb-4 border-bottom pb-4">
                <div class="col-md-6">
                    <h5 class="text-muted mb-3">Thông tin chung</h5>
                    <p class="mb-1"><strong>Mã đơn hàng:</strong> #@Model.OrderId</p>
                    <p class="mb-1"><strong>Ngày đặt hàng:</strong> @Model.Orderdate?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <h5 class="text-muted mb-3">Thông tin giao hàng</h5>
                    <p class="mb-1"><strong>Người nhận:</strong> @Model.Customer?.Name</p>
                    <p class="mb-1"><strong>Số điện thoại:</strong> @Model.Customer?.Phone</p>
                    <p class="mb-1"><strong>Địa chỉ giao:</strong> @(Model.Address?.Address ?? "Chưa cập nhật địa chỉ")</p>
                </div>
            </div>

            <h5 class="text-muted mb-3">Sản phẩm đã mua</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            decimal totalAmount = 0;
                        }
                        @foreach (var detail in Model.TbOrderDetails)
                        {
                            // Giả định bảng TbOrderDetail của bạn có cột Quantity, nếu không có tạm để là 1
                            int quantity = 1; // detail.Quantity (sửa lại nếu db có cột này)
                            decimal price = detail.Price;
                            decimal subTotal = quantity * price;
                            totalAmount += subTotal;

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@detail.Product?.Image" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;" alt="@detail.Product?.Name">
                                        <span class="fw-bold">@detail.Product?.Name</span>
                                    </div>
                                </td>
                                <td class="text-center">@quantity</td>
                                <td class="text-end">@string.Format("{0:#,##0} đ", price)</td>
                                <td class="text-end fw-bold text-danger">@string.Format("{0:#,##0} đ", subTotal)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="row mt-4">
                <div class="col-md-6 offset-md-6">
                    <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded">
                        <h5 class="mb-0 text-muted">Tổng cộng:</h5>
                        <h3 class="mb-0 text-danger fw-bold">@string.Format("{0:#,##0} đ", totalAmount)</h3>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center">
                <a href="/Login/Profile" class="btn btn-outline-secondary px-4 rounded-pill">Quay lại danh sách đơn hàng</a>
            </div>
        </div>
    </div>
</div>