@model IEnumerable<WebBanHang.Models.TbOrder>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-box-seam"></i> Quản lý đơn hàng</h2>
        @* Nút chuyển nhanh sang trang sản phẩm *@
        <a href="@Url.Action("ManageProducts", "AdminUser")" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Quay lại Quản lý sản phẩm
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Trạng thái hiện tại</th>
                        <th class="text-center">Thao tác xử lý</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">#@item.OrderId</td>
                            <td>
                                <div class="fw-bold">@item.Customer?.Name</div>
                                <small class="text-muted">@item.Customer?.Phone</small>
                            </td>
                            <td>@(item.Orderdate?.ToString("dd/MM/yyyy HH:mm"))</td>
                            <td>
                                @if (item.Status == 0)
                                {
                                    <span class="badge bg-secondary">Đã hủy</span>
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="badge bg-info text-dark">Đang giao hàng</span>
                                }
                                else if (item.Status == 3)
                                {
                                    <span class="badge bg-success">Đã hoàn thành</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @* Nút Xác nhận giao hàng: Hiện khi đơn mới (Status 1) *@
                                    @if (item.Status == 1)
                                    {
                                        <form asp-action="ConfirmDelivery" asp-controller="AdminUser" method="post">
                                            <input type="hidden" name="id" value="@item.OrderId" />
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="bi bi-truck"></i> Xác nhận giao
                                            </button>
                                        </form>
                                    }

                                    @* Nút Hoàn thành: Hiện khi đang giao (Status 2) *@
                                    @if (item.Status == 2)
                                    {
                                        <form asp-action="CompleteOrder" asp-controller="AdminUser" method="post">
                                            <input type="hidden" name="id" value="@item.OrderId" />
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="bi bi-check-lg"></i> Hoàn thành
                                            </button>
                                        </form>
                                    }
                                    
                                    @if(item.Status == 0 || item.Status == 3)
                                    {
                                        <span class="text-muted small">Đã xử lý xong</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>