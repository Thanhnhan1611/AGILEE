@model IEnumerable<WebBanHang.Models.TbPorduct>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📦 Quản lý sản phẩm</h2>
        <a asp-action="CreateProduct" class="btn btn-primary shadow-sm">+ Thêm sản phẩm</a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Hình</th>
                        <th>Tên sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng tồn</th> @* THÊM CỘT MỚI *@
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">#@item.ProductId</td>
                            <td><img src="@item.Image" width="50" height="50" class="rounded object-fit-cover border" /></td>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-danger">@string.Format("{0:#,##0} đ", item.Price)</td>
                            
                            @* HIỂN THỊ SỐ LƯỢNG TỒN *@
                            <td>
                                @if (item.Quanlity <= 0)
                                {
                                    <span class="badge bg-danger">Hết hàng</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@item.Quanlity</span>
                                }
                            </td>

                            <td class="text-center">
                                <a asp-action="EditProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @* Tiêu chí: Có xác nhận trước khi xóa *@
                                <form asp-action="DeleteProduct" asp-route-id="@item.ProductId" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                            onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>