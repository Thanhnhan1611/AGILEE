@model IEnumerable<WebBanHang.Models.TbCustomer>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid py-4">
    @* --- PHẦN TIÊU ĐỀ VÀ NÚT CHUYỂN HƯỚNG --- *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Quản lý Tài Khoản Hệ Thống</h2>
        <div>
            <a asp-action="ManageProducts" class="btn btn-dark shadow-sm px-4">
                <i class="bi bi-box-seam me-2"></i> Quản lý Sản phẩm
            </a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- PHẦN TÌM KIẾM (GIỮ NGUYÊN) --- *@
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-8">
                    <input type="text" name="search" class="form-control" placeholder="Nhập tên hoặc email để tìm kiếm..." value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search"></i> Tìm kiếm</button>
                    <a href="/AdminUser/Index" class="btn btn-outline-secondary">Làm mới</a>
                </div>
            </form>
        </div>
    </div>

    @* --- BẢNG DANH SÁCH (THÊM CỘT SỐ ĐIỆN THOẠI & ĐỊA CHỈ) --- *@
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Họ Tên</th>
                            <th>Email</th>
                            <th>Số điện thoại</th> @* Thêm mới *@
                            <th>Địa chỉ</th>      @* Thêm mới *@
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>#@user.CustomerId</td>
                                <td class="fw-bold">@user.Name</td>
                                <td>@user.Email</td>
                                <td>@(user.Phone ?? "N/A")</td> @* Hiển thị SĐT *@
                                <td>@(user.Address ?? "N/A")</td> @* Hiển thị Địa chỉ *@
                                
                                <td>
                                    @if (user.Status == 1)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Đã khóa</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <form asp-action="ToggleLock" method="post" onsubmit="return confirmAction(event, 'Bạn có chắc muốn thay đổi trạng thái tài khoản này?');">
                                            <input type="hidden" name="id" value="@user.CustomerId" />
                                            @if (user.Status == 1)
                                            {
                                                <button type="submit" class="btn btn-sm btn-warning" title="Khóa tài khoản"><i class="bi bi-lock-fill"></i> Khóa</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-success" title="Mở khóa tài khoản"><i class="bi bi-unlock-fill"></i> Mở khóa</button>
                                            }
                                        </form>

                                        <form asp-action="DeleteUser" method="post" onsubmit="return confirmAction(event, 'Cảnh báo: Hành động này sẽ xóa vĩnh viễn tài khoản. Tiếp tục?');">
                                            <input type="hidden" name="id" value="@user.CustomerId" />
                                            <button type="submit" class="btn btn-sm btn-danger" title="Xóa tài khoản"><i class="bi bi-trash"></i> Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted">
                    <p>Không tìm thấy người dùng nào phù hợp.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmAction(e, message) {
            e.preventDefault();
            var form = e.target;
            
            Swal.fire({
                title: 'Xác nhận thao tác',
                text: message,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }
    </script>
}