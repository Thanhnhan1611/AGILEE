@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebBanHang</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebBanHang.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">🛍️ WebBanHang</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (Context.Session.GetString("Username") != null)
                        {
                            var roleId = Context.Session.GetInt32("Role");

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-success fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    @if (roleId == 1)
                                    {
                                        <text>Xin chào Admin</text>
                                    }
                                    else
                                    {
                                        <text>Xin chào, @Context.Session.GetString("FullName")</text>
                                    }
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">

                                    @if (roleId == 1)
                                    {
                                        <li><h6 class="dropdown-header text-danger fw-bold"><i class="bi bi-shield-lock-fill"></i> MENU QUẢN TRỊ</h6></li>
                                        <li><a class="dropdown-item text-danger" asp-controller="AdminUser" asp-action="Index">👥 Quản lý Tài khoản</a></li>
                                        <li><a class="dropdown-item text-danger" asp-controller="AdminUser" asp-action="ManageProducts">📦 Quản lý Sản phẩm</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item" href="/Login/Profile">👤 Thông tin cá nhân</a></li>
                                        <li><a class="dropdown-item" href="/Order/History">🧾 Lịch sử mua hàng</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }

                                    <li>
                                        <a class="dropdown-item text-dark" asp-area="" asp-controller="Login" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right text-danger"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-sm mt-1 me-2" asp-area="" asp-controller="Login" asp-action="Index">Đăng nhập</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-2">
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Cart">
                                <i class="bi bi-cart4 fs-4 text-primary"></i>
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                <strong class="text-success">@TempData["SuccessMessage"]</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container py-3">
            &copy; 2026 - WebBanHang - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
